{
  "manifest_version": 3,
  "name": "RE Radar",
  "version": "1.0.0",
  "description": "Search German real estate portals and score investment properties — no bots, no API fees",
  "permissions": ["tabs", "storage", "scripting", "alarms", "sidePanel"],
  "host_permissions": [
    "https://www.immowelt.de/*",
    "https://www.immobilienscout24.de/*",
    "https://www.ohne-makler.net/*",
    "https://www.immonet.de/*",
    "https://www.kleinanzeigen.de/*",
    "https://plutobi.github.io/*",
    "https://api.anthropic.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://plutobi.github.io/RE-Rader/*"],
      "js": ["dashboard_sync.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "RE Radar",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
